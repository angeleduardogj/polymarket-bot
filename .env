# ============================================================
# Polymarket Crypto 5-Minute Prediction Bot — Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# In simulation mode (TEST_MODE=true) no API keys are needed.

# --- Mode ---
TEST_MODE=true                          # true = simulation only, false = real trading

# --- Risk Parameters ---
RISK_PER_TRADE=1.0                      # USD per bet when trend is clear (max 1 USD)
MIN_RISK_PER_TRADE=0.25                 # USD per bet when trend is weak/neutral
MAX_DAILY_RISK=10.0                     # Maximum total USD wagered per day
MAX_CONSECUTIVE_LOSS=5.0                # Stop trading if cumulative consecutive losses >= this

# --- Crypto Assets ---
CRYPTO_LIST=BTC,ETH,SOL,XRP            # Comma-separated list of cryptos to monitor

# --- Signal Filters ---
MIN_VOLATILITY_PERCENT=0.05             # Skip candles with < this % price change
AGGRESSIVE_MODE=false                   # If true, bet MIN_RISK on neutral signals too

# --- Fee & Spread Simulation ---
MIN_FEE_PERCENT=0.5                    # Minimum Polymarket trading fee (%)
MAX_FEE_PERCENT=1.5                    # Maximum Polymarket trading fee (%)
MIN_SPREAD_PERCENT=0.5                 # Minimum Binance-to-Polymarket price spread (%)
MAX_SPREAD_PERCENT=2.0                 # Maximum Binance-to-Polymarket price spread (%)

# --- Binance (optional — only needed if a library requires it) ---
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Polymarket (required only when TEST_MODE=false) ---
POLYMARKET_PRIVATE_KEY=                 # Polygon wallet private key
POLYMARKET_FUNDER_ADDRESS=              # Address that holds your funds on Polymarket
POLYMARKET_SIGNATURE_TYPE=0             # 0=EOA, 1=email/Magic, 2=browser proxy

# --- Polymarket Endpoints (defaults should work) ---
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYMARKET_WSS_MARKET=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_WSS_USER=wss://ws-subscriptions-clob.polymarket.com/ws/user

# --- Logging ---
LOG_DIR=logs                            # Directory for daily CSV trade logs
